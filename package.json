{
  "name": "fastfood-chain",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "db:schema": "node -e \"require('dotenv').config();const fs=require('fs');const mysql=require('mysql2/promise');(async()=>{const c=await mysql.createConnection({host:process.env.DB_HOST,user:process.env.DB_USER,password:process.env.DB_PASSWORD||'',database:process.env.DB_NAME||'fastfood_chain',multipleStatements:true});await c.query(fs.readFileSync('database/schema.sql','utf8'));console.log('Schema OK');process.exit(0);})().catch(e=>{console.error(e);process.exit(1);})\""
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.0"
  }
}
